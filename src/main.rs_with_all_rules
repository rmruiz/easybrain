// rule 4: if all pairs of points that contain point x sum a value greater than the zone sum,
// discard point x
fn rule_4(matrix: &Vec<Vec<i32>>, zone: &mut Zone, is_discarded: &mut Vec<Vec<bool>>, is_confirmed: &mut Vec<Vec<bool>>) {
    
    let mut partial_sum = zone.sum;

    //remove all confirmed points from the sum
    for point in zone.points.iter(){
        let i = point[0] as usize;
        let j = point[1] as usize;
        if is_confirmed[i][j] {
            partial_sum -= matrix[i][j];
        }
    }
    //print_zone(&zone, &matrix, &is_discarded, &is_confirmed);
    //println!("with partial sum: {}", partial_sum);

    //select one point each time
    for point2 in zone.points.iter() {
        let x = point2[0] as usize;
        let y = point2[1] as usize;
        if is_discarded[x][y] || is_confirmed[x][y] {
            continue;
        }
        //println!("Checking point ({}, {}) with value: {}", x, y, matrix[x][y]);

        let mut drop_point2 = false;
        for point3 in zone.points.iter() {
            let i = point3[0] as usize;
            let j = point3[1] as usize;
            //println!("Checking against point ({}, {}) with value: {}", i, j, matrix[i][j]);
            if is_discarded[i][j] || is_confirmed[i][j] || (x == i && y == j) || matrix[x][y] == partial_sum {
                //println!("Skipping");
                //if is_discarded[i][j] { println!("--> Point ({}, {}) is already discarded", i, j); }
                //else if is_confirmed[i][j] { println!("--> Point ({}, {}) is already confirmed", i, j); }
                //else if x == i && y == j { println!("--> Point 1 and 2 are the same"); }
                //else if matrix[x][y] == partial_sum { println!("--> Point ({}, {}) value is = partial_sum", i, j); }
                continue;
            }
            
            //check if the sum of the two points is lower than the zone sum
            //println!("Comparing {} + {} < {}", matrix[x][y], matrix[i][j], partial_sum);
            if (matrix[x][y] + matrix[i][j]) <= partial_sum {
                drop_point2 = false;
                //println!("Keeping");
                break;
            } else {
                drop_point2 = true;
            }              
        }
        if drop_point2 {
            is_discarded[x][y] = true;
            println!("Discarding element at ({}, {}): {} - Rule 4", x, y, matrix[x][y]);
            break;
        }
    }
}

// rule 3: If the sum of all the not discarderd points but one in a zone is lower than the zone sum 
// minus the value of the point, confirm that point.
fn rule_3(matrix: &Vec<Vec<i32>>, zone: &mut Zone, is_discarded: &Vec<Vec<bool>>, is_confirmed: &mut Vec<Vec<bool>>) {
    //print_zone(&zone, &matrix, &is_discarded, &is_confirmed);
    for point in zone.points.iter() {
        let i = point[0] as usize;
        let j = point[1] as usize;
        if is_discarded[i][j] || is_confirmed[i][j] {
            continue;
        }
    
        let mut sum_other_points = 0;
        for point2 in zone.points.iter() {
            let i2 = point2[0] as usize;
            let j2 = point2[1] as usize;
            if is_discarded[i2][j2] || (i == i2 && j == j2) {
                continue;
            }   
            sum_other_points += matrix[i2][j2];         
        }
        if sum_other_points < zone.sum {
            is_confirmed[i][j] = true;
            println!("Confirming element at ({}, {}): {} - Rule 3", i, j, matrix[i][j]);
        }
    }
}

// rule 2: If the sum of the zone points (not disabled) exactly matches the zone sum,
// confirm all elements in that zone and mark zone as done.
fn rule_2(matrix: &Vec<Vec<i32>>, zone: &mut Zone, is_discarded: &Vec<Vec<bool>>, is_confirmed: &mut Vec<Vec<bool>>) {
    let mut sum = 0;
    for point in zone.points.iter() {
        let i = point[0] as usize;
        let j = point[1] as usize;
        if !is_discarded[i][j] {
            sum += matrix[i][j];
        }
    }
    if sum == zone.sum {
        for point in zone.points.iter() {
            let i = point[0] as usize;
            let j = point[1] as usize;
            if !is_discarded[i][j] {
                is_confirmed[i][j] = true;
                println!("Confirming element at ({}, {}): {} - Rule 2", i, j, matrix[i][j]);
            }
        }
        zone.done = true;
    }
}

//rule 1: Discard points in zone that are greater than the zone sum
fn rule_1(matrix: &Vec<Vec<i32>>, zone: &Zone, is_discarded: &mut Vec<Vec<bool>>) {
    for point in zone.points.iter() {
        let i = point[0] as usize;
        let j = point[1] as usize;
        if !is_discarded[i][j] && matrix[i][j] > zone.sum {
            is_discarded[i][j] = true;
            println!("Discarding element at ({}, {}): {} - Rule 1", i, j, matrix[i][j]);
        }
    }
}

fn count_not_discarded_or_not_confirmed(
    is_discarded: &Vec<Vec<bool>>,
    is_confirmed: &Vec<Vec<bool>>,
    n: usize,
) -> i32 {
    let mut count = 0;
    for i in 0..n {
        for j in 0..n {
            if !is_discarded[i][j] && !is_confirmed[i][j] {
                count += 1;
            }
        }
    }
    return count;
}

