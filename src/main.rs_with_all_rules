struct Zone {
    sum: i32,
    points: Vec<[i32; 2]>,
    done: bool,
}

fn main() {
    let mut zones: Vec<Zone> = Vec::new();
    let filename = "input";
    let mut matrix = add_zones(&mut zones, filename).unwrap();
    let n = matrix.len();
    let mut is_discarded: Vec<Vec<bool>> = vec![vec![false; n]; n];
    let mut is_confirmed: Vec<Vec<bool>> = vec![vec![false; n]; n];

    print_matrix(&matrix, &is_discarded, &is_confirmed);

    //solve
    let mut pending = count_not_discarded_or_not_confirmed(&is_discarded, &is_confirmed, n);
    println!("Pending: {}", pending);

    while pending > 0 {
       let mut last_pending = pending;

        // Run all the rules to discard elements
        for z in zones.iter_mut() {
            if z.done { continue; }
            //rule_1(&matrix, &z, &mut is_discarded);
            //rule_2(&matrix, z, &is_discarded, &mut is_confirmed);
            //rule_3(&matrix, z, &is_discarded, &mut is_confirmed);
            //rule_4(&matrix, z, &mut is_discarded, &mut is_confirmed);
            rule_6(&matrix, z, &mut is_discarded, &mut is_confirmed);
            //rule_7(&matrix, z, &mut is_discarded, &mut is_confirmed);
        }

        // check if any elements were discarded
        pending = count_not_discarded_or_not_confirmed(&is_discarded, &is_confirmed, n);
        println!("Pending: {}", pending);

        if pending == last_pending {
            println!("Was not able to discard or confirm any more elements");
            print_matrix(&matrix, &is_discarded, &is_confirmed);
            break;
        }
    }

    println!("solved!");
    print_matrix(&matrix, &is_discarded, &is_confirmed);
}

fn combine(
    input: &[[i32; 2]],
    r: usize,
    current: &mut Vec<[i32; 2]>,
    output: &mut Vec<Vec<[i32; 2]>>
) {
    if current.len() == r {
        output.push(current.clone());
        return;
    }

    let start = if current.is_empty() {
        0
    } else {
        let last_index = input.iter().position(|x| x == current.last().unwrap()).unwrap();
        last_index + 1
    };

    for i in start..input.len() {
        current.push(input[i]);
        combine(input, r, current, output);
        current.pop();
    }
}

fn print_zone(zone: &Zone, matrix: &Vec<Vec<i32>>, is_discarded: &Vec<Vec<bool>>, is_confirmed: &Vec<Vec<bool>>) {
    println!("Zone sum: {}", zone.sum);
    for point in zone.points.iter() {
        let i = point[0] as usize;
        let j = point[1] as usize;
        if is_discarded[i][j] {
            print!("D[{},{}]={:?} ", i, j, matrix[i][j]);
        } else if is_confirmed[i][j] {
            print!("o[{},{}]={:?} ", i, j, matrix[i][j]);
        } else {
            print!("?[{},{}]={:?} ", i, j, matrix[i][j]);
        }
    }
    println!();
}

// rule 7: if all not discarded points sum is equal to zone sum 
// confirm all non confirmed points and mark zone as done
fn rule_7(matrix: &Vec<Vec<i32>>, zone: &mut Zone, is_discarded: &mut Vec<Vec<bool>>, is_confirmed: &mut Vec<Vec<bool>>) {
    let mut sum = 0;
    for point in zone.points.iter() {
        let i = point[0] as usize;
        let j = point[1] as usize;
        if is_discarded[i][j] { continue; }
        sum += matrix[i][j];
    }
    if sum == zone.sum {
        for point in zone.points.iter() {
            let i = point[0] as usize;
            let j = point[1] as usize;
            if is_discarded[i][j] { continue; }
            if is_confirmed[i][j] { continue; }
            is_confirmed[i][j] = true;
            println!("Confirming element at ({}, {}): {} - Rule 7", i, j, matrix[i][j]);
        }
        zone.done = true;
    }
}

// rule 6: confirm point, if all combinations that total the zone sum contain x
fn rule_6(matrix: &Vec<Vec<i32>>, zone: &mut Zone, is_discarded: &mut Vec<Vec<bool>>, is_confirmed: &mut Vec<Vec<bool>>) {
    //print_zone(zone, matrix, is_discarded, is_confirmed);
    //is_discarded[0][0] = true;
    //is_confirmed[0][1] = true;
    //is_confirmed[1][0] = true;
    //print_zone(zone, matrix, is_discarded, is_confirmed);

    //println!("target sum = {}", zone.sum);

    let results = valid_combinations(zone, is_discarded, is_confirmed);

    //filter from results ones that sum matches for zone.sum
    let filtered: Vec<Vec<[i32; 2]>> = results.clone().into_iter()
    .filter(|combo| {
        let sum: i32 = combo.iter()
            .map(|[i, j]| matrix[*i as usize][*j as usize])
            .sum();
        sum == zone.sum
    })
    .collect();

    //println!("{:?} ",filtered);

    if filtered.is_empty() {
        //println!("No vectors match the sum condition.");
        return;
    }

    //confirmed common points

    let mut iter = filtered.clone().into_iter();
    let first_set: HashSet<_> = iter.next().unwrap().into_iter().collect();

    let common = iter.fold(first_set, |acc, v| {
        let current_set: HashSet<_> = v.into_iter().collect();
        acc.intersection(&current_set).cloned().collect()
    });

    //println!("Common elements: {:?}", common);
    for c in common.iter() {
        let i = c[0] as usize;
        let j = c[1] as usize;
        if is_confirmed[i][j] == false {
            is_confirmed[i][j] = true;
            println!("Confirming element at ({}, {}): {} - Rule 6", i, j, matrix[i][j]);
        }
    }

    //discard point not found in any filtered result
    // Step 1: Collect all points from original result into a set
    let mut original_points: HashSet<(i32, i32)> = HashSet::new();
    for combo in results {
        for p in combo {
            original_points.insert(p.into());
        }
    }
    //println!("list original: {:?}",original_points);

    // Step 2: Collect all points from filtered into a set
    let mut filtered_points: HashSet<(i32, i32)> = HashSet::new();
    for combo in filtered {
        for p in combo {
            filtered_points.insert(p.into());
        }
    }
    //println!("list filtered: {:?}",filtered_points);


    // Step 3: Convert back to tobe_discarded: Vec<[i32; 2]>
    // tobe_discarded are all points in original_points that are not in filtered_points
    let tobe_discarded: Vec<[i32; 2]> = original_points
        .difference(&filtered_points)
        .map(|&(i, j)| [i, j])
        .collect();

    //println!("Points to be discarded: {:?}", tobe_discarded);

    for p in tobe_discarded.iter() {
        let i = p[0] as usize;
        let j = p[1] as usize;
        if !is_discarded[i][j] {
            is_discarded[i][j] = true;
            println!("Discarding element at ({}, {}): {} - Rule 6", i, j, matrix[i][j]);
        }
    }

}

fn valid_combinations(
    zone: &Zone,
    is_discarded: &Vec<Vec<bool>>,
    is_confirmed: &Vec<Vec<bool>>
) -> Vec<Vec<[i32; 2]>> {
    // 1. Filter out discarded points
    let valid_points: Vec<[i32; 2]> = zone.points
        .iter()
        .cloned()
        .filter(|[i, j]| !is_discarded[*i as usize][*j as usize])
        .collect();

    // 2. Determine which of the valid points are confirmed
    let confirmed_points: Vec<[i32; 2]> = valid_points
        .iter()
        .cloned()
        .filter(|[i, j]| is_confirmed[*i as usize][*j as usize])
        .collect();

    let mut all_combinations = Vec::new();

    // 3. Generate all non-empty combinations
    for r in 1..=valid_points.len() {
        combine(&valid_points, r, &mut Vec::new(), &mut all_combinations);
    }

    // 4. Filter combinations to only those that contain all confirmed points
    let filtered = all_combinations.into_iter().filter(|combo| {
        confirmed_points.iter().all(|cp| combo.contains(cp))
    }).collect();

    filtered
}

