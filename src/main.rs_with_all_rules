                print!(" X ");
            } else {
                print!(" {:?} ", matrix[i][j]);
            }
        }
    println!();
    }
}

fn add_zones(zones: &mut Vec<Zone>, filename: &str) -> Result<Vec<Vec<i32>>, std::io::Error> {
    let path = Path::new(filename);
    let file = File::open(path)?;
    let mut lines = io::BufReader::new(file).lines();

    // Read the size of the matrix
    let n: usize = lines.next()
        .ok_or_else(|| io::Error::new(io::ErrorKind::UnexpectedEof, "Missing size line"))??
        .trim()
        .parse()
        .expect("Invalid number for matrix size");

    // Read column sums
    let column_sums: Vec<i32> = lines.next()
        .ok_or_else(|| io::Error::new(io::ErrorKind::UnexpectedEof, "Missing column sums"))??
        .split_whitespace()
        .map(|s| s.parse().expect("Invalid number in column sums"))
        .collect();

    // add columns to the zones
    for i in 0..n {
        let mut column = Zone {
            sum: column_sums[i],
            points: Vec::new(),
            done: false,
        };
        for j in 0..n { column.points.push([j as i32, i as i32]); } 
        zones.push(column);
    }

    // Read row sums (from bottom to top)
    let row_sums: Vec<i32> = lines.next()
        .ok_or_else(|| io::Error::new(io::ErrorKind::UnexpectedEof, "Missing row sums"))??
        .split_whitespace()
        .map(|s| s.parse().expect("Invalid number in row sums"))
        .collect();

    // add rows to the zones
    for j in 0..n {
        let mut row = Zone {
            sum: row_sums[j],
            points: Vec::new(),
            done: false,
        };
        for i in 0..n { row.points.push([j as i32, i as i32]); }
        zones.push(row);
    }

    // Read the actual grid data
    let mut matrix: Vec<Vec<i32>> = Vec::with_capacity(n);
    for _ in 0..n {
        let row: Vec<i32> = lines.next()
            .ok_or_else(|| io::Error::new(io::ErrorKind::UnexpectedEof, "Missing matrix row"))??
            .split_whitespace()
            .map(|s| s.parse().expect("Invalid number in matrix row"))
            .collect();
        matrix.push(row);
    }

    // Read the zone distribution
    let mut zone_distribution: Vec<Vec<i32>> = Vec::with_capacity(n);
    for _ in 0..n {
        let zone_row: Vec<i32> = lines.next()
            .ok_or_else(|| io::Error::new(io::ErrorKind::UnexpectedEof, "Missing zone distribution row"))??
            .split_whitespace()
            .map(|s| s.parse().expect("Invalid number in zone distribution row"))
            .collect();
        zone_distribution.push(zone_row);
    }

    let total_zones = zone_distribution
    .iter()
    .flat_map(|row| row.iter())
    .max()
    .copied() // Option<i32>
    .unwrap_or(0); // Default to 0 if the matrix is empty

    // Read the zone sums
    let zone_sums: Vec<i32> = lines.next()
        .ok_or_else(|| io::Error::new(io::ErrorKind::UnexpectedEof, "Missing row sums"))??
        .split_whitespace()
        .map(|s| s.parse().expect("Invalid number in row sums"))
        .collect();

    for z in 1..(total_zones+1) {
        let mut zone = Zone {
            sum: zone_sums[(z-1) as usize],
            points: Vec::new(),
            done: false,
        };
        for i in 0..n {
            for j in 0..n {
                if zone_distribution[i][j] == z {
                    zone.points.push([i as i32, j as i32]);
                }
            }
        }
        zones.push(zone);
    }
    Ok(matrix)
}

